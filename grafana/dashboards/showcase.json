{
  "uid": "graf-zahl-showcase",
  "title": "Graf Zahl — Observability Showcase",
  "tags": ["showcase", "otel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "definition": "label_values(deployment_environment)",
        "query": { "query": "label_values(deployment_environment)", "refId": "env" },
        "current": { "text": "production", "value": "production" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Golden signals — $environment",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Request rate",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(http_server_request_duration_count{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "100 * sum(rate(http_server_request_duration_count{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\", http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_duration_count{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}[$__rate_interval])), 0.0001)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_bucket{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}[$__rate_interval])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "JVM heap used",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(jvm_memory_used{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\", jvm_memory_type=\"heap\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by route",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (http_route) (rate(http_server_request_duration_count{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}[$__rate_interval]))",
          "legendFormat": "{{http_route}}",
          "exemplar": true
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request latency p95 by route  —  click an exemplar (◆) to open the trace",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}[$__rate_interval])))",
          "legendFormat": "{{http_route}}",
          "exemplar": true
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Custom app metric — work duration p95 (Micrometer → OTLP)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(app_work_duration_bucket{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}[$__rate_interval])))",
          "legendFormat": "work p95",
          "exemplar": true
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM memory & threads",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (jvm_memory_type) (jvm_memory_used{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"})",
          "legendFormat": "mem {{jvm_memory_type}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Logs — $environment (trace_id links to Tempo)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },
    {
      "type": "logs",
      "title": "Application logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"graf-zahl-demo\", deployment_environment=\"$environment\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Traces — $environment",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "type": "table",
      "title": "Recent traces (click a Trace ID to open the trace view)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.deployment.environment = \"$environment\" }",
          "tableType": "traces",
          "limit": 20
        }
      ]
    },
    {
      "type": "row",
      "title": "Continuous profiling (Pyroscope) — $environment",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 }
    },
    {
      "type": "flamegraph",
      "title": "CPU profile",
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 44 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
          "queryType": "profile",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"graf-zahl-demo\", environment=\"$environment\"}"
        }
      ]
    }
  ]
}
